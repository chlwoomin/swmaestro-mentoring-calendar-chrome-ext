{
  "manifest_version": 3,
  "name": "소마 달력 뷰어",
  "description": "AI·SW마에스트로 접수내역을 달력 형식으로 표시합니다.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["identity"],
  "host_permissions": [
    "https://www.googleapis.com/",
    "*://www.swmaestro.ai/*",
    "*://swmaestro.ai/*"
  ],
  "oauth2": {
    "client_id": "1031697495484-p5epavs1sath3gu4c9clum5grg0e2cap.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.events",
      "https://www.googleapis.com/auth/calendar.readonly"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.swmaestro.ai/sw/mypage/*",
        "*://swmaestro.ai/sw/mypage/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "calendar.css"
      ],
      "run_at": "document_idle"
    }
  ]
}